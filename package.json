{
  "name": "block-runner",
  "version": "0.0.1",
  "description": "Play through Bitcoin's onchain history. A top-down roguelike where every Bitcoin block is a deterministic level.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "idb-keyval": "^6.2.1",
    "phaser": "^3.80.1",
    "seedrandom": "^3.0.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/seedrandom": "^3.0.8",
    "eslint": "^9.13.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.13.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
